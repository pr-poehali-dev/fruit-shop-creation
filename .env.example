# ==========================================
# ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ
# ==========================================

# Пароль для базы данных (придумайте любой сложный)
POSTGRES_PASSWORD=your_strong_password_here

# Пароль для хранилища файлов (MinIO)
MINIO_ROOT_PASSWORD=your_minio_password_here

# IP или домен вашего сервера (без http://)
# Примеры: 192.168.1.100  или  myshop.ru
SERVER_HOST=localhost

# ==========================================
# ALFABANK / ОПЛАТА (если нужна онлайн-оплата)
# ==========================================

# API-токен от Alfabank (получить в личном кабинете)
ALFABANK_API_TOKEN=

# ==========================================
# TELEGRAM-УВЕДОМЛЕНИЯ (если нужны)
# ==========================================

# Токен вашего Telegram-бота (создать через @BotFather)
TELEGRAM_BOT_TOKEN=

# ID чата куда приходят уведомления о заказах
ADMIN_TELEGRAM_CHAT_ID=

# ==========================================
# GOOGLE-ВХОД (если нужен)
# ==========================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================================
# ПРОЧЕЕ
# ==========================================

# Порт на котором будет открыт сайт (80 = стандартный HTTP)
FRONTEND_PORT=80

# Логин администратора MinIO (можно оставить как есть)
MINIO_ROOT_USER=minioadmin

# Секретный код для входа в admin-режим
ADMIN_CODE=
