# =============================================================================
#  НАСТРОЙКИ САЙТА — скопируй в .env и заполни свои значения
#  cp .env.example .env
# =============================================================================

# ─── База данных ──────────────────────────────────────────────────────────────
# Придумай сложный пароль (буквы + цифры, минимум 16 символов)
POSTGRES_PASSWORD=придумай_сложный_пароль_123

# ─── Хранилище файлов MinIO (для картинок товаров) ────────────────────────────
MINIO_ROOT_USER=minioadmin
# Придумай сложный пароль
MINIO_ROOT_PASSWORD=придумай_minio_пароль_456

# ─── Адрес твоего сервера ─────────────────────────────────────────────────────
# Укажи IP адрес сервера (или домен если есть)
SERVER_HOST=111.222.333.444

# Порт сайта (80 = стандартный, не менять без причины)
FRONTEND_PORT=80

# ─── URL для доступа к картинкам и файлам ─────────────────────────────────────
# Если только IP (без домена):
S3_PUBLIC_URL=http://111.222.333.444:9000
# Если есть домен:
# S3_PUBLIC_URL=https://myshop.ru:9000

# ─── Адрес API бэкенда (куда фронтенд обращается) ────────────────────────────
# Если только IP (без домена):
VITE_API_BASE_URL=http://111.222.333.444:8000
# Если есть домен + HTTPS (с Traefik):
# VITE_API_BASE_URL=https://myshop.ru/api

# ─── Альфа-Банк (онлайн-оплата) ──────────────────────────────────────────────
# Получи токен в личном кабинете Альфа-Банка
# Оставь пустым если оплата не нужна
ALFABANK_API_TOKEN=

# ─── Telegram-бот (уведомления о заказах) ────────────────────────────────────
# 1. Создай бота через @BotFather в Telegram — получишь токен
# 2. Узнай свой Chat ID через @userinfobot
# Оставь пустым если уведомления не нужны
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# ─── Вход через Google ───────────────────────────────────────────────────────
# Создай приложение на console.cloud.google.com
# Оставь пустым если Google-авторизация не нужна
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Код доступа в админку ───────────────────────────────────────────────────
# Дополнительный пин-код для входа в административную панель
# Оставь пустым если не нужен
ADMIN_CODE=

# ─── HTTPS с автоматическим SSL сертификатом (Let's Encrypt) ─────────────────
# Заполни только если у тебя есть домен и он уже указывает на этот сервер
# Затем запускай: docker compose --profile https up -d --build
# DOMAIN=myshop.ru
# ACME_EMAIL=my@email.ru
